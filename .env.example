# ── Nexus Learn — Environment Config ──────────────────────────
# Copy this file: cp .env.example .env
# Fill in real values. NEVER commit .env to git.

# MongoDB connection string
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_real_secret

# Ollama base URL (default when running locally)
OLLAMA_URL=http://localhost:11434

# Ollama model name — must match what you pulled e.g. llama3, mistral, gemma2
OLLAMA_MODEL=llama3

# Flask port
PORT=5000

# YouTube Data API v3 key — get free key at https://console.cloud.google.com/
# Enable "YouTube Data API v3" in your project, then create an API key
# Free quota: 10,000 units/day (each search = 100 units = ~100 searches/day)
YOUTUBE_API_KEY=AIzaSyCXWrd_tM1cpqhhqrm4aBZ33L4VDhnojGM
